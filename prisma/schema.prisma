generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Auth (NextAuth / Auth.js) ──────────────────────────────────
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ── Users ──────────────────────────────────────────────────────
model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?   // bcrypt hash, null jika login via OAuth
  role          String    @default("Suami") // "Suami" | "Istri"
  householdId   String?

  accounts Account[]
  sessions Session[]
  transactions Transaction[]
  savingGoals SavingGoal[]
  debts Debt[]

  // Relasi ke household
  household Household? @relation(fields: [householdId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ── Household (link Suami & Istri) ─────────────────────────────
model Household {
  id     String @id @default(cuid())
  name   String @default("Keluarga")
  users       User[]
  budgets     Budget[]
  savingGoals SavingGoal[]
  debts       Debt[]
  // Invite code untuk menghubungkan akun
  inviteCode String? @unique

  createdAt DateTime @default(now())
}

// ── Categories ─────────────────────────────────────────────────
model Category {
  id     String @id @default(cuid())
  name   String @unique
  icon   String // nama lucide icon, misal "ShoppingCart"
  type   String // "pemasukan" | "pengeluaran" | "keduanya"

  transactions Transaction[]
  budgets      Budget[]

  createdAt DateTime @default(now())
}

// ── Transactions ───────────────────────────────────────────────
model Transaction {
  id          String   @id @default(cuid())
  name        String
  amount      Int      // disimpan dalam Rupiah (penuh, bukan sen)
  type        String   // "pemasukan" | "pengeluaran"
  date        DateTime
  categoryId  String
  category    Category @relation(fields: [categoryId], references: [id])
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  note        String?  @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ── Budgets ────────────────────────────────────────────────────
model Budget {
  id         String   @id @default(cuid())
  categoryId String
  category   Category @relation(fields: [categoryId], references: [id])
  limit      Int      // nominal batas budget dalam Rupiah
  period     String   // "2023-10", "2023-09", dst (YYYY-MM)
  householdId String
  household  Household @relation(fields: [householdId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([categoryId, period, householdId])
}

// ── Savings Goals ─────────────────────────────────────────────
model SavingGoal {
  id          String   @id @default(cuid())
  name        String
  target      Int      // nominal target
  collected   Int      @default(0) // sudah terkumpul
  deadline    DateTime? // nullable, opsional
  completed   Boolean  @default(false)
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  householdId String
  household   Household @relation(fields: [householdId], references: [id])

  deposits    SavingDeposit[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ── Saving Deposits (History) ────────────────────────────────
model SavingDeposit {
  id           String     @id @default(cuid())
  goalId       String
  goal         SavingGoal @relation(fields: [goalId], references: [id], onDelete: Cascade)
  amount       Int        // nominal deposit
  type         String     // "manual" | "budget" | "recurring"
  note         String?    @db.Text
  date         DateTime   @default(now())

  createdAt DateTime @default(now())
}

// ── Debts ──────────────────────────────────────────────────────
model Debt {
  id           String   @id @default(cuid())
  name         String
  lender       String   // pemberi pinjaman
  category     String   @default("Lainnya") // KPR, Kredit Mobil, Kartu Kredit, dll
  total        Int      // total utang
  remaining    Int      // sisa utang
  monthly      Int      // cicilan per bulan
  interestRate Int?     // bunga dalam persen, nullable
  dueDate      DateTime
  dueStatus    String   @default("warning") // "warning" | "paid"
  userId       String
  user         User     @relation(fields: [userId], references: [id])
  householdId  String
  household    Household @relation(fields: [householdId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
